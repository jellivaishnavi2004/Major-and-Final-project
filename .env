# ----------------------------------------------------
# 1. Django Secret Key (MANDATORY)
# You should generate a unique, strong key for production.
# ----------------------------------------------------
SECRET_KEY='your-very-long-and-secure-django-secret-key'

# ----------------------------------------------------
# 2. Database Connection (AWS RDS)
# Replace the placeholders with your actual RDS credentials.
# ----------------------------------------------------
DB_ENGINE=django.db.backends.mysql  # or .mysql, .sqlite3, .oracle
DB_NAME=your_database_name
DB_USER=your_rds_username
DB_PASSWORD=your_rds_password
DB_HOST=your-rds-instance-endpoint.rds.amazonaws.com  # The full endpoint URL
DB_PORT=5432  # 5432 for PostgreSQL, 3306 for MySQL/MariaDB, 1433 for SQL Server

# ----------------------------------------------------
# 3. Security (Optional but Recommended)
# Helps manage application access and debugging behavior.
# ----------------------------------------------------
# Set to 'False' in production for security and performance
DJANGO_DEBUG=True

# List of domain names/IPs that can access your Django app
ALLOWED_HOSTS='127.0.0.1,localhost,your-ec2-ip,your-domain.com'

# ----------------------------------------------------
# 4. Other Environment Variables (Optional)
# E.g., for AWS S3 storage or other third-party services
# ----------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# ... and so on for email, API services, etc.


# change in  settings.py Database settings
